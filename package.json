{
  "name": "grape",
  "version": "0.0.0",
  "private": true,
  "description": "The context infrastructure layer between a repository and an AI coding agent.",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "docs:check": "node scripts/check-docs-structure.mjs",
    "fixtures:check": "node scripts/check-fixtures.mjs",
    "memory:check": "node scripts/check-in-memory-loop.mjs",
    "architecture:check": "node scripts/check-architecture-boundaries.mjs",
    "storage:check": "node scripts/check-storage-migrations.mjs",
    "typecheck": "tsc --noEmit",
    "build:test": "tsc -p tsconfig.build.json",
    "test:behavior": "npm run build:test && node --no-warnings --test tests/behavior/*.test.mjs",
    "check": "npm run docs:check && npm run fixtures:check && npm run memory:check && npm run architecture:check && npm run storage:check && npm run typecheck && npm run test:behavior"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "typescript": "5.9.3"
  }
}
