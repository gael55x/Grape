{
  "name": "grape-context",
  "version": "1.0.0-beta.9",
  "description": "The context infrastructure layer between a repository and an AI coding agent.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gael55x/Grape.git"
  },
  "bugs": {
    "url": "https://github.com/gael55x/Grape/issues"
  },
  "homepage": "https://github.com/gael55x/Grape#readme",
  "type": "module",
  "bin": {
    "grape": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "plugins/",
    ".agents/plugins/marketplace.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prebuild": "node scripts/clean-dist.mjs",
    "build": "tsc -p tsconfig.dist.json",
    "postbuild": "node scripts/copy-storage-migrations.mjs",
    "docs:check": "node scripts/check-docs-structure.mjs && node scripts/check-examples.mjs",
    "fixtures:check": "node scripts/check-fixtures.mjs",
    "memory:check": "node scripts/check-in-memory-loop.mjs",
    "architecture:check": "node scripts/check-architecture-boundaries.mjs",
    "storage:check": "node scripts/check-storage-migrations.mjs",
    "typecheck": "tsc --noEmit",
    "plugin:check": "node scripts/check-codex-plugin.mjs",
    "codex:check": "node scripts/check-codex-local-workflow.mjs",
    "package:check": "npm run build && npm run plugin:check && node scripts/check-package.mjs",
    "install:check": "node scripts/check-install-smoke.mjs",
    "global:smoke": "node scripts/check-global-install-smoke.mjs",
    "bench": "node benchmarks/scripts/run-benchmarks.mjs",
    "bench:post-beta": "node benchmarks/scripts/run-post-beta-baseline.mjs --artifact published-beta",
    "bench:post-beta:local": "node benchmarks/scripts/run-post-beta-baseline.mjs --artifact local-candidate",
    "bench:comparators": "node benchmarks/scripts/run-comparator.mjs",
    "bench:summary": "node benchmarks/scripts/summarize-results.mjs",
    "benchmark:run": "node scripts/run-benchmark-suite.mjs",
    "test:connect": "node scripts/run-beta-client-trial.mjs",
    "beta:client-trial": "npm run test:connect",
    "e2e:alpha": "node scripts/e2e-alpha-smoke.mjs",
    "beta:check": "npm run check && npm run benchmark:run && npm run e2e:alpha && npm run test:connect",
    "prepack": "npm run build",
    "build:test": "tsc -p tsconfig.build.json",
    "test:behavior": "node scripts/clean-test-build.mjs && npm run build:test && node scripts/run-behavior-tests.mjs",
    "check": "npm run docs:check && npm run fixtures:check && npm run memory:check && npm run architecture:check && npm run storage:check && npm run typecheck && npm run package:check && npm run codex:check && npm run install:check && npm run test:behavior"
  },
  "dependencies": {
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@types/node": "22.19.19"
  }
}
